RETURNS VARCHAR(255)
BEGIN
     result VARCHAR(255);

    IF n % 2 = 0 THEN
        SET result = CONCAT('Factorial: ', fact, ' | Even Number');
    ELSE
        SET result = CONCAT('Factorial: ', fact, ' | Odd Number');
    END IF;

    RETURN result;
END //

