12 . Write a query structure for Triggers/SP/Views/CTE/Sub query types

Stored procedures :

DELIMITER //

CREATE PROCEDURE procedure_name(IN param1 datatype, OUT param2 datatype)
BEGIN
    -- SQL logic
END //

DELIMITER ;

1 . IN parameter :

CREATE PROCEDURE get_customer_by_id(IN cust_id INT)
BEGIN
    SELECT * FROM customers WHERE id = cust_id;
END;

2 . Out parameter :

CREATE PROCEDURE get_total_count(OUT total INT)
BEGIN
    SELECT COUNT(*) INTO total FROM customers;
END;

3 . INOUT parameter :

CREATE PROCEDURE update_value(INOUT num INT)
BEGIN
    SET num = num * 2;
END;

